{
  "name": "@synapsync/kyro-workflow",
  "version": "3.13.0",
  "description": "Portable sprint workflow kit for AI coding agents, with markdown artifacts, adapter guides, and formal debt tracking",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kyro-workflow": "dist/cli/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "check:versions": "node scripts/check-version-sync.js",
    "check:pack": "npm pack --dry-run",
    "check:post-edit": "node scripts/post-edit-scan.js",
    "check:pre-commit": "node scripts/pre-commit-checkpoint.js",
    "kyro:sprint-number": "node scripts/sprint-number.js",
    "kyro:debt-inherit": "node scripts/debt-inherit.js",
    "kyro:metrics": "node scripts/metrics-aggregate.js",
    "kyro:state": "node scripts/state.js",
    "kyro:migrate-state": "node scripts/migrate-state.js",
    "kyro:render-state": "node scripts/render-state.js",
    "kyro:gate": "node scripts/gate-decision.js",
    "kyro:worktree-task": "node scripts/worktree-task.js",
    "kyro:rules-memory": "node scripts/rules-memory.js",
    "kyro:harness-detect": "node scripts/harness-detect.js",
    "eval:deterministic": "node evals/run-evals.js",
    "eval:install-smoke": "node evals/install-smoke.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-agents",
    "agent-workflow",
    "llm-workflow",
    "agentic-development",
    "markdown-workflow",
    "workflow",
    "sprint",
    "planning",
    "execution",
    "debt-tracking",
    "roadmap",
    "iterative",
    "adaptive",
    "agents",
    "claude-code",
    "self-correction",
    "worktrees",
    "context-persistence"
  ],
  "author": {
    "name": "SynapSync",
    "url": "https://github.com/SynapSync"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SynapSync/kyro-workflow"
  },
  "homepage": "https://synapsync.dev/cognitives/kyro-workflow",
  "skills": [
    "./skills/sprint-forge",
    "./skills/qa-review"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist",
    "commands",
    "agents",
    "skills",
    "scripts",
    "schemas",
    "evals",
    "adapters",
    "docs",
    "rules",
    "contexts",
    "templates",
    "config.json",
    "WORKFLOW.yaml",
    ".claude-plugin",
    "settings.example.json",
    "README.md"
  ]
}
